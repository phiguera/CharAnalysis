# ── Phase 3: Peak flags (cols 16-20) ─────────────────────────────────────────
cat("\n=== Phase 3: Peak flags (cols 16-20) ===\n")
col3_labels <- c(
"16" = "charPeakInsig",
"17" = "charPeakSig",
"18" = "charPeakFinal",
"19" = "charPeakMag",
"20" = "charPeakMagSig"
)
for (j in 16:20) {
