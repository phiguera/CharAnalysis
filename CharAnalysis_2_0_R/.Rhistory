cat(sprintf("  col %2d %-28s  agree=%d/%d (%d disagree)  NA: R=%d MAT=%d\n",
j, col3_labels[as.character(j)],
agree, total, total - agree,
sum(is.na(rv)), sum(is.na(mv))))
} else {
d <- if (any(ok)) max(abs(rv[ok] - mv[ok])) else NA
cat(sprintf("  col %2d %-28s  max|diff| = %.6g   NA: R=%d MAT=%d\n",
j, col3_labels[as.character(j)], d,
sum(is.na(rv)), sum(is.na(mv))))
}
}
