# Run the pipeline on the bundled Code Lake dataset
params_file <- system.file("validation", "CO_charParams.csv",
package = "CharAnalysis")
out <- CharAnalysis(params_file)
char_plot_peaks(out)
char_plot_fri(out)            # has the "yr fire^-1" label
char_plot_fire_history(out)   # has the "yr^-1" label
char_plot_all(out)            # all eight, no save
> char_plot_peaks(out)
char_plot_peaks(out)
devtools::load_all(".")
out <- CharAnalysis(system.file("validation", "CO_charParams.csv",
package = "CharAnalysis"))
# All three previously broken figures:
char_plot_peaks(out)            # both y-axis labels (panels A and B)
char_plot_fire_history(out)     # top panel "peak mag." was the broken third one
char_plot_zones(out)            # CDF x-axis and box-plot y-axis
devtools::check(args = c("--as-cran", "--run-donttest"))
devtools::check_win_devel()
devtools::check_win_devel()
