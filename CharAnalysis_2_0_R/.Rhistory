# Reproduce the zone loop logic exactly as char_post_process sees it
library(MASS)
charcoal_cp <- out$charcoal
T_thresh    <- ncol(charcoal_cp$charPeaks)
ccp         <- charcoal_cp$charPeaks     # charcoal_charpeaks
zone_div    <- out$pretreatment$zoneDiv
bin_width   <- 20L
bin_edges   <- seq(bin_width, 1000L, by = bin_width)
bin_centers <- bin_edges[-length(bin_edges)] + bin_width / 2L
for (z in seq_len(length(zone_div) - 1L)) {
cat("\n--- Zone", z, "---\n")
x_plot <- charcoal_cp$ybpI[ccp[, T_thresh] > 0]
x_plot <- x_plot[x_plot >= zone_div[z] & x_plot < zone_div[z + 1L]]
fri_z  <- diff(x_plot)
fri_z  <- fri_z[is.finite(fri_z)]
cat("  peaks:", length(x_plot), "  FRIs:", length(fri_z),
"  max FRI:", if(length(fri_z)) max(fri_z) else NA, "\n")
if (length(fri_z) <= 1L || max(fri_z) > 5000) {
cat("  -> SKIP: length/max guard\n"); next
}
fri_z_bins <- fri_z[fri_z >= bin_edges[1L] & fri_z < bin_edges[length(bin_edges)]]
freq_tab   <- graphics::hist(fri_z_bins, breaks = bin_edges,
plot = FALSE, right = FALSE)$counts
ok <- freq_tab > 0L
cat("  bins populated:", sum(ok), "  sum(freq_tab):", sum(freq_tab), "\n")
if (sum(ok) < 2L || sum(freq_tab) == 0L) {
cat("  -> SKIP: bins guard\n"); next
}
x_rep   <- rep(bin_centers[ok], freq_tab[ok])
cat("  x_rep:", x_rep, "\n")
fit_wbl <- tryCatch(
suppressWarnings(MASS::fitdistr(x_rep, "weibull")),
error = function(e) { cat("  fitdistr error:", conditionMessage(e), "\n"); NULL }
)
if (is.null(fit_wbl)) { cat("  -> SKIP: fitdistr failed\n"); next }
cat("  -> OK  scale =", fit_wbl$estimate["scale"],
" shape =", fit_wbl$estimate["shape"], "\n")
}
