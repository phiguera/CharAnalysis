if (length(fri2_bins) > 0) {
freq_tab <- graphics::hist(fri2_bins, breaks = bin_edges, plot = FALSE, right = FALSE)$counts
cat("Bins with count > 0:", sum(freq_tab > 0), "\n")
} else {
cat("No FRIs fall within bin range — zone skipped by sum(ok) < 2 guard.\n")
}
