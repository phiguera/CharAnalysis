paste(m_ages[!round(m_ages,4) %in% round(r_ages,4)], collapse=", ")))
# ── comparison helper ─────────────────────────────────────────────────────────
cmp <- function(j, label, binary = FALSE, note = "") {
rv <- as.numeric(r_al[, j]);  mv <- as.numeric(m_al[, j])
ok <- !is.na(rv) & !is.na(mv)
if (binary) {
ag <- sum(rv[ok] == mv[ok]);  tot <- sum(ok)
cat(sprintf("  col %2d %-30s agree=%d/%d (%d disagree)  NA: R=%d M=%d%s\n",
j, label, ag, tot, tot-ag, sum(is.na(rv)), sum(is.na(mv)), note))
} else {
d <- if (any(ok)) max(abs(rv[ok] - mv[ok])) else NA
cat(sprintf("  col %2d %-30s max|diff|=%-12.6g  NA: R=%d M=%d%s\n",
j, label, d, sum(is.na(rv)), sum(is.na(mv)), note))
}
}
# ── Phase 1 ───────────────────────────────────────────────────────────────────
cat("\n=== Phase 1: Interpolation (cols 1-6) ===\n")
for (j in 1:6) cmp(j, c("cm","ybpI","countI","volI","conI","accI")[j])
# ── Phase 2 ───────────────────────────────────────────────────────────────────
cat("\n=== Phase 2: Background / Thresholds (cols 7-15) ===\n")
labs2 <- c("charBkg","charPeak","thresh1","thresh2","thresh3",
"threshFinalPos","threshFinalNeg","SNI","GOF_pval")
for (j in 7:15) {
note <- if (j %in% 7:8) "  *** known smooth() diff ***" else ""
cmp(j, labs2[j-6], note=note)
}
# ── Phase 3 ───────────────────────────────────────────────────────────────────
cat("\n=== Phase 3: Peak flags (cols 16-20) ===\n")
labs3 <- c("peaks1","peaks2","peaks3","peaksFinal","peaksInsig")
for (j in 16:20) cmp(j, labs3[j-15], binary=(j<=19))
cat(sprintf("\n  R   peaks Final (col 19==1): %d\n", sum(r_si17[,19]==1, na.rm=TRUE)))
cat(sprintf("  MAT peaks Final (col 19==1): %d\n", sum(mat[,19]==1, na.rm=TRUE)))
# ── Phase 4 ───────────────────────────────────────────────────────────────────
cat("\n=== Phase 4: Peak mag / FRI / zone stats (cols 21-33) ===\n")
labs4 <- c("peakMag","smPeakFrequ","smFRIs","nFRIs","mFRI",
"mFRI_uCI","mFRI_lCI","WBLb","WBLb_uCI","WBLb_lCI",
"WBLc","WBLc_uCI","WBLc_lCI")
for (j in 21:33) {
note <- if (j==23) "  (R computes, MATLAB=NaN)" else ""
cmp(j, labs4[j-20], note=note)
}
CharWriteResults(out$char_results, out$site, out_dir = file.path(base, "tests"))
# ── save SI17 ────────────────────────────────────────────────────────────────
base <- "C:/Users/philip.higuera/Documents/Claude/Projects/CharAnalysis 2.0/CharAnalysis_2_0_R"
CharWriteResults(out$char_results, out$site, out_dir = file.path(base, "tests"))
# ── load RA07 reference and run ───────────────────────────────────────────────
mat_raw <- read.csv(file.path(base, "tests/RA07_charResults.csv"), header = FALSE)
mat     <- matrix(as.numeric(as.matrix(mat_raw)), nrow = nrow(mat_raw))
out_ra  <- CharAnalysis(file.path(base, "tests/RA07_charParams.csv"))
r_ra07  <- out_ra$char_results
cat(sprintf("R dims: %d x %d    MATLAB dims: %d x %d\n",
nrow(r_ra07), ncol(r_ra07), nrow(mat), ncol(mat)))
# ── align on age (col 2) ──────────────────────────────────────────────────────
r_ages <- r_ra07[, 2];  m_ages <- mat[, 2]
common  <- intersect(round(r_ages, 4), round(m_ages, 4))
r_al    <- r_ra07[!is.na(match(round(r_ages, 4), common)), ]
m_al    <- mat[!is.na(match(round(m_ages, 4), common)), ]
r_al    <- r_al[order(r_al[, 2]), ];  m_al <- m_al[order(m_al[, 2]), ]
cat(sprintf("Aligned: %d rows  |  MAT-only ages: %s\n",
nrow(r_al),
paste(m_ages[!round(m_ages,4) %in% round(r_ages,4)], collapse=", ")))
# ── comparison helper (reuse from before) ────────────────────────────────────
cmp <- function(j, label, binary = FALSE, note = "") {
rv <- as.numeric(r_al[, j]);  mv <- as.numeric(m_al[, j])
ok <- !is.na(rv) & !is.na(mv)
if (binary) {
ag <- sum(rv[ok] == mv[ok]);  tot <- sum(ok)
cat(sprintf("  col %2d %-30s agree=%d/%d (%d disagree)  NA: R=%d M=%d%s\n",
j, label, ag, tot, tot-ag, sum(is.na(rv)), sum(is.na(mv)), note))
} else {
d <- if (any(ok)) max(abs(rv[ok] - mv[ok])) else NA
cat(sprintf("  col %2d %-30s max|diff|=%-12.6g  NA: R=%d M=%d%s\n",
j, label, d, sum(is.na(rv)), sum(is.na(mv)), note))
}
}
# ── All phases ────────────────────────────────────────────────────────────────
cat("\n=== Phase 1: Interpolation (cols 1-6) ===\n")
for (j in 1:6) cmp(j, c("cm","ybpI","countI","volI","conI","accI")[j])
cat("\n=== Phase 2: Background / Thresholds (cols 7-15) ===\n")
labs2 <- c("charBkg","charPeak","thresh1","thresh2","thresh3",
"threshFinalPos","threshFinalNeg","SNI","GOF_pval")
for (j in 7:15) {
note <- if (j %in% 7:8) "  *** known smooth() diff ***" else ""
cmp(j, labs2[j-6], note=note)
}
cat("\n=== Phase 3: Peak flags (cols 16-20) ===\n")
labs3 <- c("peaks1","peaks2","peaks3","peaksFinal","peaksInsig")
for (j in 16:20) cmp(j, labs3[j-15], binary=(j<=19))
cat(sprintf("\n  R   peaks Final (col 19==1): %d\n", sum(r_ra07[,19]==1, na.rm=TRUE)))
cat(sprintf("  MAT peaks Final (col 19==1): %d\n", sum(mat[,19]==1, na.rm=TRUE)))
cat("\n=== Phase 4: Peak mag / FRI / zone stats (cols 21-33) ===\n")
labs4 <- c("peakMag","smPeakFrequ","smFRIs","nFRIs","mFRI",
"mFRI_uCI","mFRI_lCI","WBLb","WBLb_uCI","WBLb_lCI",
"WBLc","WBLc_uCI","WBLc_lCI")
for (j in 21:33) {
note <- if (j==23) "  (R computes, MATLAB=NaN)" else ""
cmp(j, labs4[j-20], note=note)
}
